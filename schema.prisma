generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Você pode alterar para postgresql ou mysql
  url      = "file:./dev.db"
}

model Produto {
  id      String @id @default(uuid())
  nome    String
  custo   Float
  preco   Float
  estoque Int
}

model Venda {
  id        String      @id @default(uuid())
  data      String
  hora      String
  total     Float
  itens     ItemVenda[]
  createdAt DateTime    @default(now())
}

model ItemVenda {
  id      String @id @default(uuid())
  nome    String
  preco   Float
  qtd     Int
  vendaId String
  venda   Venda  @relation(fields: [vendaId], references: [id])
}
